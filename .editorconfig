root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{js,jsx,ts,tsx,json,css,scss,md,yml,yaml}]
indent_size = 2

[*.cs]
indent_size = 4
csharp_new_line_before_open_brace = all

[*.md]
trim_trailing_whitespace = false
