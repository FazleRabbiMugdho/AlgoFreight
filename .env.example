# === Database (Neon PostgreSQL) ===
# ConnectionStrings__Default is the .NET env-var convention that overrides appsettings.json ConnectionStrings:Default.
# For a local Postgres instance, use: Host=localhost;Port=5432;Database=algofreight;Username=postgres;Password=changeme
# For Neon, use: Host=ep-<project>.pooler-<region>.aws.neon.tech;Database=algofreight;Username=<user>;Password=<password>;SSL Mode=Require
ConnectionStrings__Default=Host=localhost;Port=5432;Database=algofreight;Username=postgres;Password=changeme

# === Auth ===
JWT_SECRET=replace-with-a-long-random-secret
JWT_ISSUER=AlgoFreight
JWT_AUDIENCE=AlgoFreightClient

# === AI Integration ===
GEMINI_API_KEY=your-gemini-api-key-here

# === Frontend ===
VITE_API_BASE_URL=http://localhost:5000
VITE_SIGNALR_HUB_URL=http://localhost:5000/hubs/dispatch
