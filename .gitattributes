# Auto-normalize line endings to LF in the repo, OS-native on checkout.
* text=auto

# C# / .NET
*.cs     text diff=csharp
*.csproj text
*.sln    text
*.json   text
*.yml    text
*.yaml   text
*.md     text diff=markdown
*.sh     text eol=lf

# Binaries
*.dll    binary
*.exe    binary
*.png    binary
*.jpg    binary
*.ico    binary
*.ttf    binary
